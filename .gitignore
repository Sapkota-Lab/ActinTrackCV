# OS
.DS_Store

# Python
__pycache__/
*.pyc
.pytest_cache/
.env
.venv/
venv/
.ipynb_checkpoints/

# PyInstaller build artifacts
/build/
/dist/

# Release archives (built locally and attached to GitHub Releases; not tracked)
*.zip

# Local sample workspace (runtime data tree mirroring raw_source; not source).
# Sample videos are already covered by the media rules below; this also keeps
# generated workspace metadata (samples.csv, crop_metadata.json) out of git.
/samples/

# Workspace runtime metadata (root only; tests/fixtures exempt)
/metadata/
!/tests/fixtures/v1_workspace/metadata/

# Local workspace data trees
/raw/
/processed/
/previews/
/raw_source/

# Extracted research frame data (kept locally, not tracked)
/frames/
/frames_index.csv

# Icon source exports (kept locally; canonical icons live in packaging/assets/app/)
/actintrackcv_icon_exports/
/actintrackcv_icons_transparent/

# Runtime workspace metadata accidentally created inside the local z-stack import
/20260608_WT_Z stacks/metadata/
/20260608_WT_Z stacks/raw/

# Microscopy / media (local copies; not repo fixtures)
*.tif
*.tiff
*.nd2
*.czi
*.lif
*.oib
*.oir
*.png
*.jpg
*.jpeg
*.mp4
*.avi

# Packaging assets must be tracked despite the global *.png ignore above
!packaging/assets/
!packaging/assets/**/*.png
!packaging/assets/**/*.ico
!packaging/assets/**/*.icns

# Documentation source of truth is Markdown; do not commit Word docs
*.docx
~$*.docx

# Project-specific
models/
outputs/
local_context/
/actintrackcv_macos_exports/
